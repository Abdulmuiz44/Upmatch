generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ConnectedAccountProvider {
  UPWORK
}

enum ConnectedAccountStatus {
  PENDING
  ACTIVE
  REVOKED
  ERROR
}

enum ContractTypePreference {
  HOURLY
  FIXED_PRICE
  BOTH
}

enum JobUserStateType {
  NEW
  SAVED
  DISMISSED
  APPLIED
}

model User {
  id                String             @id @default(cuid())
  email             String             @unique
  passwordHash      String
  fullName          String?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  connectedAccounts ConnectedAccount[]
  freelancerProfile FreelancerProfile?
  preference        UserPreference?
  jobScores         JobScore[]
  jobStates         JobUserState[]

  @@index([createdAt])
}

model ConnectedAccount {
  id                    String                 @id @default(cuid())
  userId                String
  provider              ConnectedAccountProvider
  status                ConnectedAccountStatus @default(PENDING)
  externalAccountId     String?
  tenantId              String?
  scope                 String?
  encryptedAccessToken  String?
  encryptedRefreshToken String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  lastSyncedAt          DateTime?
  errorCode             String?
  errorMessage          String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, userId])
  @@index([userId, status])
  @@index([provider, tenantId])
}

model FreelancerProfile {
  id                  String   @id @default(cuid())
  userId              String   @unique
  upworkProfileId     String?  @unique
  profileTitle        String?
  overview            String?
  hourlyRateUsdCents  Int?
  profileUrl          String?
  categories          String[]
  skills              String[]
  rawPayload          Json?
  syncedAt            DateTime?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([syncedAt])
}

model UserPreference {
  id                    String                 @id @default(cuid())
  userId                String                 @unique
  preferredRoles        String[]
  preferredKeywords     String[]
  excludedKeywords      String[]
  preferredIndustries   String[]
  minimumHourlyRateUsd  Decimal?               @db.Decimal(10, 2)
  minimumFixedBudgetUsd Decimal?               @db.Decimal(10, 2)
  contractType          ContractTypePreference @default(BOTH)
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contractType])
}

model Job {
  id                    String         @id @default(cuid())
  providerJobId         String         @unique
  providerCiphertext    String?
  title                 String
  description           String
  contractType          String?
  experienceLevel       String?
  hourlyMinUsd          Decimal?       @db.Decimal(10, 2)
  hourlyMaxUsd          Decimal?       @db.Decimal(10, 2)
  fixedBudgetUsd        Decimal?       @db.Decimal(10, 2)
  durationLabel         String?
  category              String?
  skills                String[]
  clientCountry         String?
  clientTotalHires      Int?
  clientTotalPostedJobs Int?
  clientTotalReviews    Int?
  clientTotalFeedback   Decimal?       @db.Decimal(5, 2)
  publishedAt           DateTime?
  firstSeenAt           DateTime       @default(now())
  lastSeenAt            DateTime       @default(now())
  expiresAt             DateTime
  rawPayload            Json?
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  scores                JobScore[]
  states                JobUserState[]

  @@index([publishedAt])
  @@index([expiresAt])
  @@index([lastSeenAt])
}

model JobScore {
  id              String   @id @default(cuid())
  userId          String
  jobId           String
  overallScore    Int
  skillScore      Int
  keywordScore    Int
  budgetScore     Int
  preferenceScore Int
  freshnessScore  Int
  penaltyScore    Int
  explanation     Json
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  job             Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, overallScore])
}

model JobUserState {
  id        String           @id @default(cuid())
  userId    String
  jobId     String
  state     JobUserStateType @default(NEW)
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job              @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId, state])
}
